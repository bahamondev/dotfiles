set nocompatible

filetype indent plugin on

syntax on

set wildmenu

set showcmd

set hlsearch

set ignorecase
set smartcase

set autoindent

set ruler

set nostartofline

set laststatus=2

set confirm

set visualbell

set mouse=a

set cmdheight=2

set number

set shiftwidth=4
set softtabstop=4
set expandtab

